---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Nav } from '../../components/Nav';
import { Footer } from '../../components/Footer';
import { Reserve } from '../../components/Reserve';
import { optimize } from '../../lib/images';
import { TRIMS } from '../../data/gt';
import type { OptimizedImage } from '../../types';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const endpoint = import.meta.env.PUBLIC_FORM_ENDPOINT ?? '';

// Build-time optimize every trim render → pass the typed map to the island.
const entries = await Promise.all(
  TRIMS.map(async (t) => {
    const img = await optimize(t.image, { width: 980, mobileWidth: 620, alt: `The VANTA GT in ${t.name}` });
    return [t.id, img] as const;
  })
);
const renders: Record<string, OptimizedImage> = Object.fromEntries(entries);
---

<BaseLayout
  title="Reserve the GT"
  description="Reserve your VANTA GT. Choose a finish, leave your details, and hold your build slot with a fully refundable deposit."
>
  <Nav slot="nav" base={base} client:only="react" />

  <section class="section pt-32 lg:pt-40 relative overflow-hidden">
    <div class="glow absolute inset-0 opacity-60" aria-hidden="true"></div>
    <div class="bgtypo text-[length:clamp(6rem,20vw,18rem)] -top-[2%] -left-[4%] opacity-80" aria-hidden="true">RESERVE</div>
    <span class="float-line left-[12%] top-0 h-[40%]" aria-hidden="true"></span>
    <span class="float-dot right-[18%] top-[28%]" aria-hidden="true"></span>

    <header class="container-wide relative z-[2] mb-12 lg:mb-16">
      <p class="kicker"><span class="ping" aria-hidden="true"></span> RESERVATIONS · OPEN</p>
      <h1 class="mt-5 font-display text-[length:var(--text-4xl)] max-w-[16ch] leading-[0.95]">
        Hold your place<br />in the <span class="text-[var(--plasma-2)]">dark</span>.
      </h1>
      <p class="mt-5 text-[length:var(--text-lg)] text-[var(--muted)] max-w-[52ch] leading-relaxed">
        Three steps, a refundable deposit, no commitment. First-built GTs go to the earliest reservations — this is how you get to the front of the line.
      </p>
    </header>

    <Reserve base={base} renders={renders} endpoint={endpoint} client:visible />
  </section>

  <Footer slot="footer" base={base} client:visible />
</BaseLayout>
