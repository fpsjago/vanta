# VANTA — environment variables
# Copy to `.env` and fill in. All PUBLIC_ vars are exposed to the client bundle.

# Form endpoint for the Reserve + Contact forms.
# Paste a Formspree-style POST URL (e.g. https://formspree.io/f/xxxxxx).
# Leave EMPTY to use the built-in graceful in-page success (no network call) —
# ideal for demoing the template before you wire up a real backend.
PUBLIC_FORM_ENDPOINT=
